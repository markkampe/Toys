#!/bin/bash

HEIGHT=55	# usually on horizontal monitor
WIDTH=72	# don't take up too much room
GEOMETRY="-geometry $WIDTH"x"$HEIGHT"

EDITOR=/usr/bin/gvim

# figure out where today's diary should be
if [ `hostname` == "Sagredo" ]
then
	# Sagredo is where the real diaries live
	MONTH=`date "+%b%y"`
	YEAR=`date "+%Y"`
	DIR="$HOME/Diaries/$YEAR"
	FILE="$MONTH.txt"
elif [ `hostname` == "Binah" ]
then
	# on Binah we just keep an rsync'd local changes file
	DIR="$HOME/WIP"
	FILE="TP_diary.txt"
fi

if [ -f $DIR/$FILE ]
then
    echo using existing $FILE in $DIR
else
    echo creating new $FILE in $DIR
fi

( cd $DIR; $EDITOR $GEOMETRY $FILE ) &
